# env.dokploy.example
# ====================
# Template delle variabili da incollare nel pannello "Environment" su Dokploy
# per i due servizi `app` (Next.js) e `worker` (scraper).
#
# Architettura: MySQL e Redis sono SERVIZI DOKPLOY GESTITI separati.
# La loro Connection URL interna va incollata qui sotto, NON ricostruita
# manualmente. Ogni servizio gestito ha un hostname univoco e quindi non
# è soggetto al DNS round-robin di `dokploy-network`.
#
# ⚠️ Mai committare i valori reali. Tutti i secret vanno generati e
# incollati direttamente nel pannello Dokploy.

# ============================================
# SHARED — usare le STESSE per app e worker
# ============================================

# URL completa fornita dal servizio MySQL gestito di Dokploy.
# Esempio: mysql://utente:password@<hostname-univoco-dokploy>:3306/<dbname>
DATABASE_URL=mysql://USER:PASSWORD@MYSQL_HOST:3306/DBNAME

# URL completa fornita dal servizio Redis gestito di Dokploy.
# Esempio: redis://default:password@<hostname-univoco-dokploy>:6379
REDIS_URL=redis://default:PASSWORD@REDIS_HOST:6379

# VAPID keys per push notification (generare con: npx web-push generate-vapid-keys)
# La pubblica può stare in chiaro lato client; la privata è un secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@snipedeal.it

# ============================================
# APP ONLY (servizio Next.js)
# ============================================

# Dominio pubblico configurato in Dokploy per l'app
NEXTAUTH_URL=https://snipedeal.example.com

# Generare con: openssl rand -base64 32
NEXTAUTH_SECRET=

# OAuth opzionali (lasciare vuoti se non usati)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# ============================================
# WORKER ONLY
# ============================================
# Il worker non ha env aggiuntive oltre alle SHARED.
# (NODE_ENV=production e NEXT_TELEMETRY_DISABLED sono già hardcoded nei Dockerfile.)
