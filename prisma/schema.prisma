// prisma/schema.prisma - Schema database SnipeDeal 2.0 PWA
// Timestamp: 2024-12-09

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// MODELLI UTENTE E AUTENTICAZIONE
// ============================================

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String?
  role             Role      @default(USER)
  
  // Relazione con piano abbonamento
  planId           String?
  plan             Plan?     @relation(fields: [planId], references: [id])
  
  // Web Push subscription (JSON stringificato)
  pushSubscription String?   @db.Text
  
  // Relazioni
  campaigns        Campaign[]
  favorites        Favorite[]
  
  // Timestamps
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  @@index([email])
  @@index([planId])
}

enum Role {
  USER
  ADMIN
}

// ============================================
// MODELLI ABBONAMENTO
// ============================================

model Plan {
  id              String   @id @default(cuid())
  name            String   @unique  // Free, Hobby, Pro, Ultra
  description     String?
  
  // Limiti del piano
  maxCampaigns    Int      // 1, 3, 5, 10
  maxMarketplaces Int      // 1, 2, 5, 5
  frequencyMins   Int      // 180, 60, 15, 5 (minuti tra le scansioni)
  
  // Prezzo
  priceYear       Float    @default(0) // 0, 0, 199, 299
  
  // Stato
  isActive        Boolean  @default(true)
  
  // Relazioni
  users           User[]
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([name])
}

// ============================================
// MODELLI CAMPAGNA
// ============================================

model Campaign {
  id          String    @id @default(cuid())
  
  // Relazione utente
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Dati campagna
  name        String
  keyword     String
  platform    Platform  @default(SUBITO)
  
  // Filtri
  minPrice    Float?
  maxPrice    Float?
  region      String?   // Regione italiana (es. "Lombardia")
  
  // Filtri avanzati di ricerca (comuni a tutte le piattaforme)
  exactMatch      Boolean  @default(false)  // Se true, usa qso=true (ricerca solo nel titolo)
  includeKeywords String?  @db.Text         // Parole da includere (separate da virgola)
  excludeKeywords String?  @db.Text         // Parole da escludere (separate da virgola)
  
  // Filtri specifici per piattaforma (JSON flessibile)
  // Subito: { "region": "Lombardia" }
  // eBay: { "location": "IT" | "EU" }
  platformFilters Json?
  
  // Stato e scheduling
  isActive    Boolean   @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  
  // Statistiche
  totalResults Int      @default(0)
  newResults   Int      @default(0)
  
  // Relazioni
  results     Result[]
  jobLogs     JobLog[]
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([userId])
  @@index([isActive])
  @@index([nextRunAt])
  @@index([platform])
}

enum Platform {
  SUBITO
  EBAY
  VINTED
  WALLAPOP
  FACEBOOK
}

// ============================================
// MODELLI RISULTATI
// ============================================

model Result {
  id          String    @id @default(cuid())
  
  // Relazione campagna
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  // Dati annuncio
  title       String
  price       String?
  location    String?
  link        String    @db.VarChar(500)
  image       String?   @db.VarChar(500)
  
  // Stato disponibilità (se disponibile dal marketplace)
  status      String?   @default("available") // available, sold
  hasShipping Boolean   @default(false)
  
  // Notifica
  notified    Boolean   @default(false)
  isNew       Boolean   @default(true)
  
  // Data pubblicazione annuncio (dal marketplace)
  publishedAt String?   // Data come stringa dal marketplace (es: "7 min fa", "2024-12-09")
  
  // Extra data (JSON per dati specifici del marketplace)
  extraData   Json?
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Link unico per campagna (evita duplicati)
  @@unique([campaignId, link])
  @@index([campaignId])
  @@index([notified])
  @@index([isNew])
  @@index([createdAt])
  
  // Relazioni
  favorites Favorite[]
}

// ============================================
// MODELLI FAVORITES
// ============================================

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  resultId  String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  result    Result   @relation(fields: [resultId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, resultId]) // Un utente non può preferire lo stesso annuncio più volte
}

// ============================================
// MODELLI JOB LOGGING
// ============================================

model JobLog {
  id            String    @id @default(cuid())
  
  // Relazione campagna
  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  // Stato job
  status        JobStatus @default(RUNNING)
  
  // Risultati
  totalFound    Int       @default(0)
  newFound      Int       @default(0)
  notified      Int       @default(0)
  
  // Messaggi
  message       String?   @db.Text
  error         String?   @db.Text
  
  // Timing
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  durationMs    Int?
  
  @@index([campaignId])
  @@index([status])
  @@index([startedAt])
}

enum JobStatus {
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

// ============================================
// MODELLI PROXY
// ============================================

model ProxyProvider {
  id          String   @id @default(cuid())
  name        String   @unique  // "packetstream", "brightdata", etc.
  displayName String   // "Packetstream"
  isEnabled   Boolean  @default(false)
  isDefault   Boolean  @default(false)
  
  // Configurazione specifica del provider (JSON)
  // Packetstream: { username, authKey, defaultCountry }
  // BrightData: { zone, username, password }
  config      Json
  
  // Relazioni
  usageLogs   ProxyUsageLog[]
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([name])
  @@index([isEnabled])
}

model ProxyUsageLog {
  id         String   @id @default(cuid())
  
  // Relazione provider
  providerId String
  provider   ProxyProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  
  // Relazione campagna (opzionale)
  campaignId String?
  
  // Risultato
  success    Boolean
  latencyMs  Int?
  ipUsed     String?
  country    String?
  error      String?  @db.Text
  
  // Timestamp
  createdAt  DateTime @default(now())
  
  @@index([providerId])
  @@index([campaignId])
  @@index([success])
  @@index([createdAt])
}

