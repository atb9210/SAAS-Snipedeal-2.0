# env.local.example - Variabili d'ambiente per sviluppo locale
# Copia questo file come .env.local e modifica i valori se necessario
# 
# Comando rapido:
# cp env.local.example .env.local

# Database MySQL (connessione locale)
DATABASE_URL=mysql://snipedeal:snipedeal_secret_2024@localhost:3306/snipedeal

# Redis (connessione locale)
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-production-min-32-chars

# Ambiente
NODE_ENV=development

# Opzionali per sviluppo
# NEXTAUTH_DEBUG=true

# Floppydata Webunlocker
FLOPPYDATA_API_KEY=your_floppydata_api_key_here
FLOPPYDATA_BASE_URL=https://client-api.floppy.host
FLOPPYDATA_DEFAULT_COUNTRY=IT

